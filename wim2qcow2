def write_linuxmuster_desc(output_path: Path, image: WimImage, source_wim: Path) -> Path:
    desc_path = linuxmuster_desc_path(output_path)
    created = datetime.now().strftime("%d.%m.%Y")
    lines = [
        f"{created} - wim2qcow2",
        f"- Quelle: {source_wim.name}",
        f"- WIM-Index: {image.index}",
    ]
    if image.name:
        lines.append(f"- WIM-Name: {image.name}")
    if image.build:
        lines.append(f"- Build: {image.build}")
    desc_path.write_text("\n".join(lines) + "\n", encoding="utf-8")
    return desc_path


def write_linuxmuster_hooks(output_path: Path, *, donor_boot_seed: bool) -> list[Path]:
    prestart_path = linuxmuster_sidecar_path(output_path, ".prestart")
    postsync_path = linuxmuster_sidecar_path(output_path, ".postsync")
    if donor_boot_seed:
        prestart_path.write_text(linuxmuster_prestart_template(), encoding="utf-8")
        postsync_path.write_text(linuxmuster_postsync_template(), encoding="utf-8")
    else:
        prestart_path.write_text(legacy_linuxmuster_prestart_template(), encoding="utf-8")
        postsync_path.write_text(legacy_linuxmuster_postsync_template(), encoding="utf-8")
    return [prestart_path, postsync_path]


def write_linuxmuster_reg(output_path: Path) -> Path:
    reg_path = linuxmuster_sidecar_path(output_path, ".reg")
    reg_path.write_text(linuxmuster_reg_template(), encoding="utf-8")
    return reg_path


def write_linuxmuster_info(
    output_path: Path,
    target_partition: str,
    virtual_size_bytes: int,
    image_size_bytes: int,
) -> Path:
    timestamp = datetime.now().strftime("%Y%m%d%H%M")
    partition_kib = (virtual_size_bytes + 1023) // 1024
    info_path = linuxmuster_info_path(output_path)
    info_text = (
        f'["{output_path.name}" Info File]\n'
        f'timestamp="{timestamp}"\n'
        f'image="{output_path.name}"\n'
        f'imagesize="{image_size_bytes}"\n'
        f'partition="{target_partition}"\n'
        f'partitionsize="{partition_kib}"\n'
    )
    info_path.write_text(info_text, encoding="utf-8")
    return info_path


def copy_linuxmuster_reference_sidecars(reference_dir: Path, output_path: Path, logger: Logger) -> list[Path]:
    if not reference_dir.is_dir():
        raise ToolError(f"Referenzverzeichnis nicht gefunden: {reference_dir}")

    copied: list[Path] = []
    for suffix in (".reg", ".desc"):
        matches = sorted(reference_dir.glob(f"*{suffix}"))
        if not matches:
            logger.debug(f"Kein Referenz-Sidecar gefunden fuer {suffix}: {reference_dir}")
            continue
        if len(matches) > 1:
            names = ", ".join(match.name for match in matches)
            logger.warn(f"Mehrere Referenzdateien fuer {suffix} gefunden, uebersprungen: {names}")
            continue
        source = matches[0]
        if suffix == ".desc":
            destination = linuxmuster_desc_path(output_path)
        else:
            destination = linuxmuster_sidecar_path(output_path, suffix)
        shutil.copy2(source, destination)
        copied.append(destination)
    return copied


def convert_full_disk(
    input_path: Path,
    image: WimImage,
    partial_output: Path,
    logger: Logger,
    state: ConversionState,
    *,
    ntfs_label: str,
    sanitize_logodidakt: bool,
) -> str:
    logger.step("Verbinde qcow2 per NBD")
    state.nbd_device = connect_nbd(partial_output, logger)

    logger.step("Partitioniere GPT: EFI + MSR + Windows")
    efi_partition, _, windows_partition = create_gpt_layout(state.nbd_device, logger)

    logger.step("Formatiere EFI- und Windows-Partition")
    format_partitions(efi_partition, windows_partition, logger, ntfs_label=ntfs_label)

    mounts_root = make_tempdir(state)
    efi_mount = mounts_root / "efi"
    windows_mount = mounts_root / "windows"
    efi_mount.mkdir(parents=True, exist_ok=True)
    windows_mount.mkdir(parents=True, exist_ok=True)

    logger.step("Mounte Zielpartitionen")
    mount_partition(efi_partition, efi_mount, logger, fs_type="vfat", options="umask=022")
    state.mountpoints.append(efi_mount)
    mount_windows_partition(windows_partition, windows_mount, logger)
    state.mountpoints.append(windows_mount)

    logger.step("Wende WIM auf die Windows-Partition an")
    run_command(["wimlib-imagex", "apply", str(input_path), str(image.index), str(windows_mount)], logger)

    logger.step("Bereinige Windows-Setup-/Sysprep-Zustand offline")
    sanitize_applied_windows_image(windows_mount, logger, sanitize_logodidakt=sanitize_logodidakt)

    logger.step("Installiere EFI-Bootdateien")
    boot_mode = install_boot_files(
        windows_mount,
        efi_mount,
        logger,
        efi_partition=efi_partition,
        windows_partition=windows_partition,
        disk_device=state.nbd_device,
    )

    logger.step("Synchronisiere und trenne NBD")
    release_state(state, logger)
    return boot_mode


def convert_linuxmuster_partition(
    input_path: Path,
    image: WimImage,
    partial_output: Path,
    output_path: Path,
    logger: Logger,
    state: ConversionState,
    *,
    ntfs_label: str,
    sanitize_logodidakt: bool,
    reference_dir: Path | None,
    group_name: str | None,
    target_partition: str | None,
) -> bool:
    logger.step("Verbinde qcow2 per NBD")
    state.nbd_device = connect_nbd(partial_output, logger)

    logger.step("Formatiere Linuxmuster-NTFS-Volume")
    format_ntfs_target(state.nbd_device, logger, label=ntfs_label, partitioned=False)

    mounts_root = make_tempdir(state)
    windows_mount = mounts_root / "windows"
    windows_mount.mkdir(parents=True, exist_ok=True)

    logger.step("Mounte Linuxmuster-Volume")
    mount_windows_partition(state.nbd_device, windows_mount, logger)
    state.mountpoints.append(windows_mount)

    logger.step("Wende WIM auf das Linuxmuster-Volume an")
    run_command(["wimlib-imagex", "apply", str(input_path), str(image.index), str(windows_mount)], logger)

    logger.step("Bereinige Windows-Setup-/Sysprep-Zustand offline")
    sanitize_applied_windows_image(windows_mount, logger, sanitize_logodidakt=sanitize_logodidakt)

    donor_boot_seed = apply_linuxmuster_reference_boot_seed(
        windows_mount,
        output_path.stem,
        reference_dir,
        group_name,
        target_partition,
        state.nbd_device,
        logger,
    )

    logger.step("Synchronisiere und trenne NBD")
    release_state(state, logger)
    return donor_boot_seed


def convert(args: argparse.Namespace, logger: Logger) -> None:
    ensure_root()
    require_tools(required_tools_for_layout(args.layout))

    input_path = Path(args.input).resolve()
    output_path = Path(args.output).resolve()
    if not input_path.is_file():
        raise ToolError(f"Eingabe-WIM nicht gefunden: {input_path}")

    start_conf_hints = derive_start_conf_hints(Path(args.start_conf).resolve()) if args.start_conf else StartConfHints()
    metadata = parse_wim_metadata(input_path, logger)
    image = choose_image(metadata, args.index)
    disk_size_bytes = parse_size(args.disk_size)
    validate_disk_size(image, disk_size_bytes)
    partial_output = ensure_output_target(output_path, args.force)
    check_free_space(output_path.parent, image, logger)

    logger.step(f"WIM-Index {image.index}: {image.name or '(ohne Namen)'}")
    logger.step(f"Erzeuge qcow2-Container: {partial_output.name} ({args.disk_size})")
    run_command(["qemu-img", "create", "-f", "qcow2", str(partial_output), args.disk_size], logger)

    state = ConversionState(partial_output=partial_output)
    boot_mode = "not-run"
    linuxmuster_donor_seed = False
    info_path: Path | None = None
    sidecars: list[Path] = []
    try:
        if args.layout == "linuxmuster-partition":
            linuxmuster_donor_seed = convert_linuxmuster_partition(
                input_path,
                image,
                partial_output,
                output_path,
                logger,
                state,
                ntfs_label=args.ntfs_label,
                sanitize_logodidakt=args.sanitize_logodidakt,
                reference_dir=Path(args.copy_sidecars_from).resolve() if args.copy_sidecars_from else None,
                group_name=start_conf_hints.group_name or output_path.stem,
                target_partition=args.target_partition,
            )
            boot_mode = "linuxmuster-partition"
        else:
            boot_mode = convert_full_disk(
                input_path,
                image,
                partial_output,
                logger,
                state,
                ntfs_label=args.ntfs_label,
                sanitize_logodidakt=args.sanitize_logodidakt,
            )

        logger.step("Pruefe qcow2")
        check_qcow2(partial_output, logger)

        logger.step("Berechne SHA256")
        digest = sha256sum(partial_output)
        final_size = partial_output.stat().st_size

        partial_output.rename(output_path)
        state.committed = True

        if args.layout == "linuxmuster-partition":
            logger.step("Schreibe Linuxmuster-Info-Datei")
            info_path = write_linuxmuster_info(output_path, args.target_partition, disk_size_bytes, final_size)
            logger.step("Erzeuge Linuxmuster-Hooks")
            sidecars.extend(write_linuxmuster_hooks(output_path, donor_boot_seed=linuxmuster_donor_seed))
            logger.step("Erzeuge Linuxmuster-Reg-Datei")
            sidecars.append(write_linuxmuster_reg(output_path))
            logger.step("Erzeuge Linuxmuster-Desc-Datei")
            sidecars.append(write_linuxmuster_desc(output_path, image, input_path))
            if args.copy_sidecars_from:
                logger.step("Kopiere Linuxmuster-Referenzdateien aus Referenzverzeichnis")
                for copied in copy_linuxmuster_reference_sidecars(Path(args.copy_sidecars_from).resolve(), output_path, logger):
                    sidecars = [path for path in sidecars if path != copied]
                    sidecars.append(copied)

        logger.ok(f"Fertiges qcow2: {output_path}")
        print(f"Output: {output_path}")
        print(f"Size:   {human_bytes(final_size)}")
        print(f"SHA256: {digest}")
        print(f"Boot:   {boot_mode}")
        if info_path is not None:
            print(f"Info:   {info_path}")
        if sidecars:
            print("Sidecars:")
            for sidecar in sidecars:
                print(f"  - {sidecar}")
    except Exception:
        if not state.committed and partial_output.exists():
            logger.warn(f"Partielle Datei bleibt zu Diagnosezwecken erhalten: {partial_output}")
        raise
    finally:
        cleanup(state, logger)


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description=(
            "Konvertiert Windows-WIM-Images in qcow2. "
            "Unterstuetzt Voll-Disk-GPT fuer KVM/Proxmox und Linuxmuster-Partitionsimages. "
            "Ohne Argumente startet ein interaktiver Wizard."
        )
    )
    parser.add_argument("--input", help="Pfad zur Eingabe-WIM-Datei")
    parser.add_argument("--output", help="Pfad zur Ausgabe-qcow2-Datei")
    parser.add_argument("--index", type=int, help="WIM-Image-Index")
    parser.add_argument("--disk-size", default=DEFAULT_DISK_SIZE, help="Virtuelle Groesse der qcow2 bzw. Zielpartition, z.B. 64G")
    parser.add_argument(
        "--layout",
        default=DEFAULT_LAYOUT,
        choices=("full-disk-gpt", "linuxmuster-partition"),
        help="Ausgabeformat: bootfaehiges Voll-Disk-Image oder Linuxmuster-Partitionsimage",
    )
    parser.add_argument("--start-conf", help="LINBO start.conf zur Ableitung von Root-Partition, Groesse und Label")
    parser.add_argument("--target-partition", default=DEFAULT_TARGET_PARTITION, help="Zielpartition fuer .qcow2.info im Linuxmuster-Modus")
    parser.add_argument(
        "--copy-sidecars-from",
        help=(
            "Referenzverzeichnis fuer Linuxmuster-Dateien. "
            ".reg/.desc werden uebernommen; eine enthaltene .qcow2 dient als donor "
            "fuer EFI/Microsoft/Boot und .guid.*"
        ),
    )
    parser.add_argument("--ntfs-label", default=DEFAULT_NTFS_LABEL, help="NTFS-Label fuer das Zielvolume")
    parser.add_argument(
        "--sanitize-logodidakt",
        action="store_true",
        default=DEFAULT_SANITIZE_LOGODIDAKT,
        help="Entfernt logoDIDACT-, Domain-, Autologon- und lokale Group-Policy-Reste offline",
    )
    parser.add_argument("--inspect", action="store_true", help="Nur WIM analysieren und verfuegbare Images auflisten")
    parser.add_argument("--interactive", action="store_true", help="Interaktiver Wizard fuer die Konvertierung")
    parser.add_argument("--env-file", help="Pfad zu einer env-Datei mit Default-Werten fuer die Konvertierung")
    parser.add_argument("--force", action="store_true", help="Vorhandene .partial-Datei ueberschreiben")
    parser.add_argument("--logfile", help="Pfad zu einer Detail-Logdatei")
    parser.add_argument("--verbose", action="store_true", help="Zusatzinformationen und Kommandos loggen")
    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    if len(sys.argv) == 1:
        args.interactive = True
    if args.env_file:
        args = apply_env_defaults(args, parser, parse_env_file(Path(args.env_file).expanduser().resolve()))
    if args.interactive:
        args = run_interactive_wizard(args)
    logger = Logger(verbose=args.verbose, logfile=Path(args.logfile).resolve() if args.logfile else None)
    try:
        if args.copy_sidecars_from and args.layout != "linuxmuster-partition":
            parser.error("--copy-sidecars-from funktioniert nur mit --layout linuxmuster-partition")
        if not args.input:
            parser.error("--input ist erforderlich, ausser im interaktiven Modus")
        apply_start_conf_defaults(args, logger)
        require_tools(("wimlib-imagex",))
        metadata = parse_wim_metadata(Path(args.input).resolve(), logger)
        if args.inspect:
            print_wim_summary(metadata)
            return 0
        if not args.output:
            parser.error("--output ist erforderlich, ausser mit --inspect")
        convert(args, logger)
        return 0
    except ToolError as exc:
        logger.error(str(exc))
        return 1
    except KeyboardInterrupt:
        logger.error("Abgebrochen.")
        return 130
    finally:
        logger.close()


if __name__ == "__main__":
    sys.exit(main())
