class Logger:
    def __init__(self, verbose: bool = False, logfile: Path | None = None) -> None:
        self.verbose = verbose
        self.logfile = logfile
        self.use_color = sys.stderr.isatty() and os.environ.get("NO_COLOR") is None
        self.colors = {
            "step": "\033[36m",
            "ok": "\033[32m",
            "warn": "\033[33m",
            "error": "\033[31m",
            "debug": "\033[35m",
            "reset": "\033[0m",
        }
        self._log_handle = None
        if logfile is not None:
            logfile.parent.mkdir(parents=True, exist_ok=True)
            self._log_handle = logfile.open("a", encoding="utf-8")

    def close(self) -> None:
        if self._log_handle is not None:
            self._log_handle.close()
            self._log_handle = None

    def _write(self, level: str, message: str) -> None:
        prefix = f"[{level.upper()}]"
        rendered = f"{prefix} {message}"
        if self.use_color and level in self.colors:
            rendered = f"{self.colors[level]}{rendered}{self.colors['reset']}"
        print(rendered, file=sys.stderr)
        if self._log_handle is not None:
            self._log_handle.write(f"{prefix} {message}\n")
            self._log_handle.flush()

    def step(self, message: str) -> None:
        self._write("step", message)

    def ok(self, message: str) -> None:
        self._write("ok", message)

    def warn(self, message: str) -> None:
        self._write("warn", message)

    def error(self, message: str) -> None:
        self._write("error", message)

    def debug(self, message: str) -> None:
        if self.verbose:
            self._write("debug", message)

    def log_command(self, args: Sequence[str], stdout: str, stderr: str) -> None:
        if self._log_handle is None:
            return
        command = " ".join(shlex.quote(arg) for arg in args)
        self._log_handle.write(f"$ {command}\n")
        if stdout:
            self._log_handle.write(stdout)
            if not stdout.endswith("\n"):
                self._log_handle.write("\n")
        if stderr:
            self._log_handle.write(stderr)
            if not stderr.endswith("\n"):
                self._log_handle.write("\n")
        self._log_handle.flush()


def human_bytes(value: int) -> str:
    units = ("B", "KiB", "MiB", "GiB", "TiB")
    amount = float(value)
    for unit in units:
        if amount < 1024.0 or unit == units[-1]:
            if unit == "B":
                return f"{int(amount)} {unit}"
            return f"{amount:.1f} {unit}"
        amount /= 1024.0
    return f"{value} B"


def parse_size(size: str) -> int:
    raw = size.strip().upper()
    suffixes = {
        "K": 1024,
        "M": 1024 ** 2,
        "G": 1024 ** 3,
        "T": 1024 ** 4,
    }
    if raw[-1:] in suffixes:
        return int(float(raw[:-1]) * suffixes[raw[-1]])
    return int(raw)


def ensure_root() -> None:
    if os.geteuid() != 0:
        raise ToolError("Dieses Kommando braucht Root-Rechte fuer NBD, Partitionierung und Mounts.")


def require_tools(tools: Iterable[str]) -> None:
    missing = [tool for tool in tools if shutil.which(tool) is None]
    if missing:
        raise ToolError(f"Fehlende Abhaengigkeiten: {', '.join(missing)}")


def required_tools_for_layout(layout: str) -> tuple[str, ...]:
    if layout == "linuxmuster-partition":
        return REQUIRED_TOOLS_LINUXMUSTER
    return REQUIRED_TOOLS_FULL_DISK


def run_command(
    args: Sequence[str],
    logger: Logger,
    *,
    text: bool = True,
    check: bool = True,
) -> subprocess.CompletedProcess:
    logger.debug("Starte: " + " ".join(shlex.quote(arg) for arg in args))
    completed = subprocess.run(
        args,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=text,
        check=False,
    )
    stdout = completed.stdout if isinstance(completed.stdout, str) else completed.stdout.decode("utf-8", "replace")
    stderr = completed.stderr if isinstance(completed.stderr, str) else completed.stderr.decode("utf-8", "replace")
    logger.log_command(args, stdout, stderr)
    if logger.verbose and stdout.strip():
        logger.debug(stdout.strip())
    if check and completed.returncode != 0:
        detail = stderr.strip() or stdout.strip() or f"Exit-Code {completed.returncode}"
        raise ToolError(f"Befehl fehlgeschlagen: {' '.join(shlex.quote(arg) for arg in args)}\n{detail}")
    return completed


def decode_wim_xml(raw: bytes) -> str:
    if raw.startswith(codecs.BOM_UTF16_LE) or raw.startswith(codecs.BOM_UTF16_BE):
        return raw.decode("utf-16")
    return raw.decode("utf-8")


def parse_wim_metadata(wim_path: Path, logger: Logger) -> WimMetadata:
    result = run_command(["wimlib-imagex", "info", str(wim_path), "--xml"], logger, text=False)
    xml_text = decode_wim_xml(result.stdout if isinstance(result.stdout, bytes) else result.stdout.encode())
    root = ET.fromstring(xml_text)
    images: list[WimImage] = []
    for image_node in root.findall("IMAGE"):
        windows_node = image_node.find("WINDOWS")
        languages_node = windows_node.find("LANGUAGES") if windows_node is not None else None
        version_node = windows_node.find("VERSION") if windows_node is not None else None
        images.append(
            WimImage(
                index=int(image_node.attrib["INDEX"]),
                name=(image_node.findtext("NAME") or "").strip(),
                description=(image_node.findtext("DESCRIPTION") or "").strip(),
                total_bytes=int(image_node.findtext("TOTALBYTES") or "0"),
                dir_count=int(image_node.findtext("DIRCOUNT") or "0"),
                file_count=int(image_node.findtext("FILECOUNT") or "0"),
                architecture=ARCH_MAP.get(windows_node.findtext("ARCH") if windows_node is not None else "", "unknown"),
                languages=[node.text for node in (languages_node.findall("LANGUAGE") if languages_node is not None else []) if node.text],
                default_language=(languages_node.findtext("DEFAULT") if languages_node is not None else "") or "",
                edition_id=(windows_node.findtext("EDITIONID") if windows_node is not None else "") or "",
                installation_type=(windows_node.findtext("INSTALLATIONTYPE") if windows_node is not None else "") or "",
                build=(version_node.findtext("BUILD") if version_node is not None else "") or "",
                system_root=(windows_node.findtext("SYSTEMROOT") if windows_node is not None else "") or "",
            )
        )
    return WimMetadata(
        source=wim_path,
        total_bytes=int(root.findtext("TOTALBYTES") or "0"),
        images=images,
    )


def choose_image(metadata: WimMetadata, index: int | None) -> WimImage:
    if index is None:
        if len(metadata.images) == 1:
            return metadata.images[0]
        raise ToolError("Mehrere WIM-Images gefunden. Bitte --index angeben.")
    for image in metadata.images:
        if image.index == index:
            return image
    raise ToolError(f"WIM-Index {index} wurde nicht gefunden.")


def print_wim_summary(metadata: WimMetadata) -> None:
    print(f"WIM: {metadata.source}")
    print(f"Komprimierte Groesse: {human_bytes(metadata.total_bytes)}")
    print("")
    header = f"{'Index':<5} {'Name':<40} {'Groesse':>12} {'Build':>8} {'Arch':>8} {'Sprache':>10}"
    print(header)
    print("-" * len(header))
    for image in metadata.images:
        languages = ",".join(image.languages) or "-"
        name = (image.name[:37] + "...") if len(image.name) > 40 else image.name
        print(
            f"{image.index:<5} "
            f"{name:<40} "
            f"{human_bytes(image.total_bytes):>12} "
            f"{image.build or '-':>8} "
            f"{image.architecture:>8} "
            f"{languages[:10]:>10}"
        )


def prompt_text(prompt: str, default: str | None = None, *, allow_empty: bool = False) -> str:
    while True:
        suffix = f" [{default}]" if default not in (None, "") else ""
        answer = input(f"{prompt}{suffix}: ").strip()
        if answer:
            return answer
        if default is not None:
            return default
        if allow_empty:
            return ""
        print("Eingabe erforderlich.")


def prompt_yes_no(prompt: str, default: bool = False) -> bool:
    suffix = " [J/n]" if default else " [j/N]"
    while True:
        answer = input(f"{prompt}{suffix}: ").strip().lower()
        if not answer:
            return default
        if answer in {"j", "ja", "y", "yes"}:
            return True
        if answer in {"n", "nein", "no"}:
            return False
        print("Bitte j oder n eingeben.")


def prompt_choice(prompt: str, options: Sequence[tuple[str, str]], default_value: str) -> str:
    values = {str(index): value for index, (_, value) in enumerate(options, start=1)}
    labels = {str(index): label for index, (label, _) in enumerate(options, start=1)}
    reverse = {value: key for key, value in values.items()}
    for key in values:
        marker = " (Standard)" if values[key] == default_value else ""
        print(f"  {key}) {labels[key]}{marker}")
    while True:
        answer = input(f"{prompt} [{reverse.get(default_value, '1')}]: ").strip()
        if not answer:
            return default_value
        if answer in values:
            return values[answer]
        print("Bitte eine gueltige Nummer eingeben.")


def prompt_existing_path(prompt: str, default: str | None = None, *, kind: str = "file", allow_empty: bool = False) -> str:
    while True:
        suffix = f" [{default}]" if default not in (None, "") else ""
        answer = input(f"{prompt}{suffix}: ").strip()
        if allow_empty and answer == "-":
            return ""
        if not answer:
            if default is not None:
                value = default
            elif allow_empty:
                return ""
            else:
                print("Eingabe erforderlich.")
                continue
        else:
            value = answer
        path = Path(value).expanduser()
        if kind == "file" and path.is_file():
            return str(path.resolve())
        if kind == "dir" and path.is_dir():
            return str(path.resolve())
        print(f"Pfad nicht gefunden ({kind}): {path}")


def prompt_output_path(prompt: str, default: str) -> str:
    while True:
        value = prompt_text(prompt, default=default)
        path = Path(value).expanduser()
        if value.endswith(os.sep) or path.is_dir():
            path = path / Path(default).name
        if not path.parent.exists():
            print(f"Zielverzeichnis nicht gefunden: {path.parent}")
            continue
        return str(path.resolve())


def guess_start_conf_from_output(output_path: str | None) -> str | None:
    if not output_path:
        return None
    group_name = Path(output_path).stem
    if not group_name:
        return None
    guesses = (
        Path("/srv/linbo") / f"start.conf.{group_name}",
        Path("/srv/linbo") / f"start.conf-{group_name}",
        Path("/srv/linbo") / f"start.conf_{group_name}",
    )
    for guess in guesses:
        if guess.is_file():
            return str(guess.resolve())
    return None


def choose_detected_path(
    candidates: Sequence[Path],
    title: str,
    *,
    kind: str = "file",
    default_path: str | None = None,
    limit: int | None = None,
) -> str | None:
    if not candidates:
        return default_path
    shown_candidates = list(candidates[:limit]) if limit else list(candidates)
    print(title)
    options = [(str(path), str(path)) for path in shown_candidates]
    values = {str(index): value for index, (_, value) in enumerate(options, start=1)}
    labels = {str(index): label for index, (label, _) in enumerate(options, start=1)}
    default_value = default_path or str(shown_candidates[0])
    reverse = {value: key for key, value in values.items()}
    for key in values:
        marker = " (Standard)" if values[key] == default_value else ""
        print(f"  {key}) {labels[key]}{marker}")
    if limit and len(candidates) > len(shown_candidates):
        print(f"  ... {len(candidates) - len(shown_candidates)} weitere")
    while True:
        prompt_default = reverse.get(default_value, default_value)
        answer = input(f"Bitte auswaehlen oder Pfad eingeben [{prompt_default}]: ").strip()
        if not answer:
            return default_value
        if answer in values:
            return values[answer]
        path = Path(answer).expanduser()
        if kind == "file" and path.is_file():
            return str(path.resolve())
        if kind == "dir" and path.is_dir():
            return str(path.resolve())
        print("Bitte eine gueltige Nummer oder einen existierenden Pfad eingeben.")


def default_output_for_input(input_path: Path) -> Path:
    return input_path.with_suffix(".qcow2")


