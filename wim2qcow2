def remove_problematic_driver_packages(windows_mount: Path, logger: Logger) -> None:
    driverstore = windows_mount / "Windows" / "System32" / "DriverStore" / "FileRepository"
    for prefix in PROBLEMATIC_DRIVERSTORE_PREFIXES:
        for path in sorted(driverstore.glob(f"{prefix}*")):
            remove_path(path, logger)

    drivers_dir = windows_mount / "Windows" / "System32" / "drivers"
    for filename in PROBLEMATIC_DRIVER_FILES:
        remove_path(drivers_dir / filename, logger)

    inf_dir = windows_mount / "Windows" / "INF"
    for inf_path in sorted(inf_dir.glob("oem*.inf")):
        try:
            content = inf_path.read_text(encoding="latin-1", errors="ignore")
        except OSError:
            continue
        if not any(marker in content for marker in PROBLEMATIC_INF_MARKERS):
            continue
        remove_path(inf_path, logger)
        pnf_path = inf_path.with_suffix(".pnf")
        remove_path(pnf_path, logger)


def cleanup_windows_setup_artifacts(windows_mount: Path, logger: Logger) -> None:
    for relative_path in SETUP_CLEANUP_PATHS:
        remove_path(windows_mount / relative_path, logger)
    for pattern in SETUP_CLEANUP_GLOBS:
        for candidate in sorted(windows_mount.glob(pattern)):
            remove_path(candidate, logger)
    remove_problematic_driver_packages(windows_mount, logger)


def cleanup_logodidakt_artifacts(windows_mount: Path, logger: Logger) -> None:
    for relative_path in LOGODIDAKT_CLEANUP_PATHS:
        remove_path(windows_mount / relative_path, logger)
    for pattern in LOGODIDAKT_CLEANUP_GLOBS:
        for candidate in sorted(windows_mount.glob(pattern)):
            if candidate.name.lower() == "desktop.ini":
                continue
            remove_path(candidate, logger)


def fix_state_ini(windows_mount: Path, logger: Logger) -> None:
    state_ini = windows_mount / "Windows" / "Setup" / "State" / "State.ini"
    if not state_ini.is_file():
        logger.debug(f"State.ini nicht vorhanden, uebersprungen: {state_ini}")
        return
    current = state_ini.read_text(encoding="utf-8", errors="replace").strip()
    if "IMAGE_STATE_COMPLETE" in current:
        logger.debug("State.ini bereits auf IMAGE_STATE_COMPLETE")
        return
    logger.debug(f"State.ini vorher: {current!r}")
    state_ini.write_text("[State]\nImageState=IMAGE_STATE_COMPLETE\n", encoding="utf-8")
    logger.debug("State.ini auf IMAGE_STATE_COMPLETE gesetzt")


def sanitize_applied_windows_image(windows_mount: Path, logger: Logger, *, sanitize_logodidakt: bool = False) -> None:
    system_hive = windows_mount / "Windows" / "System32" / "config" / "SYSTEM"
    software_hive = windows_mount / "Windows" / "System32" / "config" / "SOFTWARE"
    if not system_hive.is_file():
        raise ToolError(f"SYSTEM-Hive fehlt: {system_hive}")
    if not software_hive.is_file():
        raise ToolError(f"SOFTWARE-Hive fehlt: {software_hive}")

    cleanup_windows_setup_artifacts(windows_mount, logger)
    fix_state_ini(windows_mount, logger)
    import_reg_patch(system_hive, r"HKEY_LOCAL_MACHINE\SYSTEM", windows_setup_system_patch(), logger)
    import_reg_patch(software_hive, r"HKEY_LOCAL_MACHINE\SOFTWARE", windows_setup_software_patch(), logger)
    if sanitize_logodidakt:
        cleanup_logodidakt_artifacts(windows_mount, logger)
        import_reg_patch(system_hive, r"HKEY_LOCAL_MACHINE\SYSTEM", windows_logodidakt_system_patch(), logger)
        import_reg_patch(software_hive, r"HKEY_LOCAL_MACHINE\SOFTWARE", windows_logodidakt_software_patch(), logger)


def wait_for_paths(paths: Sequence[Path], timeout: float = 10.0) -> None:
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        if all(path.exists() for path in paths):
            return
        time.sleep(0.25)
    missing = ", ".join(str(path) for path in paths if not path.exists())
    raise ToolError(f"Partitionen wurden nicht sichtbar: {missing}")


def connect_nbd(image_path: Path, logger: Logger, *, read_only: bool = False) -> Path:
    run_command(["modprobe", "nbd", "max_part=16"], logger)
    errors: list[str] = []
    for index in range(DEFAULT_NBD_SCAN_LIMIT):
        device = Path(f"/dev/nbd{index}")
        if not device.exists():
            continue
        args = ["qemu-nbd"]
        if read_only:
            args.append("--read-only")
        args.extend(["--connect", str(device), str(image_path)])
        result = run_command(args, logger, check=False)
        if result.returncode == 0:
            return device
        stderr = result.stderr if isinstance(result.stderr, str) else result.stderr.decode("utf-8", "replace")
        errors.append(f"{device}: {stderr.strip()}")
    raise ToolError("Kein freies NBD-Device gefunden.\n" + "\n".join(errors))


def disconnect_nbd(device: Path, logger: Logger) -> None:
    run_command(["qemu-nbd", "--disconnect", str(device)], logger, check=False)


def create_gpt_layout(device: Path, logger: Logger) -> tuple[Path, Path, Path]:
    run_command(["sgdisk", "--zap-all", str(device)], logger)
    run_command(
        [
            "sgdisk",
            "-n", "1:1MiB:+512MiB",
            "-t", "1:ef00",
            "-c", "1:EFI System",
            "-n", "2:0:+16MiB",
            "-t", "2:0c01",
            "-c", "2:Microsoft Reserved",
            "-n", "3:0:0",
            "-t", "3:0700",
            "-c", "3:Windows",
            str(device),
        ],
        logger,
    )
    run_command(["partprobe", str(device)], logger, check=False)
    efi = Path(f"{device}p1")
    msr = Path(f"{device}p2")
    windows = Path(f"{device}p3")
    wait_for_paths((efi, msr, windows))
    return efi, msr, windows


def ntfs_boot_geometry(partition: Path) -> tuple[str, str, str]:
    start_path = Path("/sys/class/block") / partition.name / "start"
    start_sector = start_path.read_text(encoding="utf-8").strip() if start_path.exists() else "0"
    return start_sector, "255", "63"


def format_ntfs_target(device: Path, logger: Logger, *, label: str, partitioned: bool) -> None:
    args = ["mkntfs", "--quick", "--label", label]
    if partitioned:
        start_sector, heads, sectors_per_track = ntfs_boot_geometry(device)
        args.extend([
            "--partition-start", start_sector,
            "--heads", heads,
            "--sectors-per-track", sectors_per_track,
        ])
    args.append(str(device))
    run_command(args, logger)


def format_partitions(efi_partition: Path, windows_partition: Path, logger: Logger, *, ntfs_label: str) -> None:
    run_command(["mkfs.fat", "-F32", "-n", "EFI", str(efi_partition)], logger)
    format_ntfs_target(windows_partition, logger, label=ntfs_label, partitioned=True)


def make_tempdir(state: ConversionState) -> Path:
    path = Path(tempfile.mkdtemp(prefix="wim2qcow2-", dir="/tmp"))
    state.tempdirs.append(path)
    return path


def mount_partition(device: Path, mountpoint: Path, logger: Logger, *, fs_type: str | None = None, options: str | None = None) -> None:
    args = ["mount"]
    if fs_type:
        args.extend(["-t", fs_type])
    if options:
        args.extend(["-o", options])
    args.extend([str(device), str(mountpoint)])
    run_command(args, logger)


def mount_windows_partition(device: Path, mountpoint: Path, logger: Logger) -> None:
    attempts = [
        (["mount", "-t", "ntfs3", str(device), str(mountpoint)], "ntfs3"),
        (["mount", "-t", "ntfs", str(device), str(mountpoint)], "ntfs"),
        (["mount", str(device), str(mountpoint)], "auto"),
    ]
    for args, label in attempts:
        result = run_command(args, logger, check=False)
        if result.returncode == 0:
            logger.debug(f"Windows-Partition mit {label} gemountet.")
            return
    raise ToolError(f"NTFS-Partition konnte nicht gemountet werden: {device}")


def copytree_merge(source: Path, target: Path) -> None:
    if source.exists():
        shutil.copytree(source, target, dirs_exist_ok=True)




def blkid_value(device: Path, field: str, logger: Logger) -> str:
    result = run_command(["blkid", "-s", field, "-o", "value", str(device)], logger, check=False)
    value = result.stdout.strip() if isinstance(result.stdout, str) else result.stdout.decode("utf-8", "replace").strip()
    if result.returncode != 0 or not value:
        raise ToolError(f"{field} konnte nicht gelesen werden: {device}")
    return value


def guid_bytes_le(guid: str) -> bytes:
    return UUID(guid).bytes_le


def reg_hex(data: bytes, *, chunk: int = 25) -> str:
    parts = [f"{byte:02x}" for byte in data]
    if not parts:
        return ""
    lines: list[str] = []
    for index in range(0, len(parts), chunk):
        segment = ",".join(parts[index:index + chunk])
        if index + chunk < len(parts):
            segment += ",\\"
        lines.append(segment)
    return "\n  ".join(lines)


def bcd_device_element(partuuid: str, disk_guid: str) -> bytes:
    return BCD_DEVICE_PREFIX + guid_bytes_le(partuuid) + BCD_DEVICE_MID + guid_bytes_le(disk_guid) + BCD_DEVICE_SUFFIX


def donor_bcd_seed_reg(efi_partuuid: str, windows_partuuid: str, disk_guid: str) -> str:
    bootmgr_hex = reg_hex(bcd_device_element(efi_partuuid, disk_guid))
    windows_hex = reg_hex(bcd_device_element(windows_partuuid, disk_guid))
    return textwrap.dedent(
        f"""\\
        Windows Registry Editor Version 5.00

        [HKEY_LOCAL_MACHINE\\BCD00000000\\Objects\\{BCD_BOOTMGR_GUID}\\Elements\\11000001]
        \"Element\"=hex:{bootmgr_hex}

        [HKEY_LOCAL_MACHINE\\BCD00000000\\Objects\\{BCD_DONOR_RESUME_GUID}\\Elements\\11000001]
        \"Element\"=hex:{windows_hex}

        [HKEY_LOCAL_MACHINE\\BCD00000000\\Objects\\{BCD_DONOR_LOADER_GUID}\\Elements\\11000001]
        \"Element\"=hex:{windows_hex}

        [HKEY_LOCAL_MACHINE\\BCD00000000\\Objects\\{BCD_DONOR_LOADER_GUID}\\Elements\\21000001]
        \"Element\"=hex:{windows_hex}
        """
    )


def write_seeded_donor_bcd(
    target_bcd: Path,
    *,
    efi_partuuid: str,
    windows_partuuid: str,
    disk_guid: str,
    logger: Logger,
) -> str:
    with tempfile.TemporaryDirectory(prefix="wim2qcow2-bcddonor-", dir="/tmp") as tempdir_name:
        tempdir = Path(tempdir_name)
        donor_bcd = tempdir / "BCD"
        reg_path = tempdir / "seed.reg"
        donor_bcd.write_bytes(base64.b64decode(BCD_DONOR_B64))
        reg_path.write_text(donor_bcd_seed_reg(efi_partuuid, windows_partuuid, disk_guid), encoding="utf-8")
        run_command(
            [
                "reged",
                "-I",
                "-C",
                str(donor_bcd),
                r"HKEY_LOCAL_MACHINE\BCD00000000",
                str(reg_path),
            ],
            logger,
            check=False,
        )
        default_guid = bcd_default_guid(donor_bcd, logger)
        if default_guid == BCD_DONOR_LOADER_GUID:
            shutil.copy2(donor_bcd, target_bcd)
            return "bcdboot-donor"
    raise ToolError("Windows-BCD-Donor konnte nicht erfolgreich auf Ziel-GUIDs gepatcht werden.")

def bcd_default_guid(bcd_path: Path, logger: Logger) -> str | None:
    with tempfile.TemporaryDirectory(prefix="wim2qcow2-bcd-", dir="/tmp") as tempdir_name:
        tempdir = Path(tempdir_name)
        export_path = tempdir / "bootmgr-default.reg"
        result = run_command(
            [
                "reged",
                "-x",
                str(bcd_path),
                r"HKEY_LOCAL_MACHINE\BCD00000000",
                rf"Objects\{BCD_BOOTMGR_GUID}\Elements\23000003",
                str(export_path),
            ],
            logger,
            check=False,
        )
        if result.returncode != 0 or not export_path.exists():
            return None
        for line in export_path.read_text(encoding="utf-8", errors="replace").splitlines():
            if line.startswith('"Element"='):
                parts = line.split('"')
                if len(parts) >= 4:
                    return parts[3]
    return None


def build_patched_bcd_template(template_bcd: Path, target_bcd: Path, logger: Logger) -> str:
    reg_text = textwrap.dedent(
        f"""\
        Windows Registry Editor Version 5.00

        [HKEY_LOCAL_MACHINE\\BCD00000000\\Objects\\{BCD_BOOTMGR_GUID}\\Elements\\23000003]
        "Element"="{BCD_TEMPLATE_EFI_GUID}"
        """
    )
    with tempfile.TemporaryDirectory(prefix="wim2qcow2-bcdpatch-", dir="/tmp") as tempdir_name:
        tempdir = Path(tempdir_name)
        patched_bcd = tempdir / "BCD"
        reg_path = tempdir / "bootmgr-default.reg"
        shutil.copy2(template_bcd, patched_bcd)
        reg_path.write_text(reg_text, encoding="utf-8")
        run_command(
            [
                "reged",
                "-I",
                "-C",
                str(patched_bcd),
                r"HKEY_LOCAL_MACHINE\BCD00000000",
                str(reg_path),
            ],
            logger,
            check=False,
        )
        default_guid = bcd_default_guid(patched_bcd, logger)
        if default_guid == BCD_TEMPLATE_EFI_GUID:
            shutil.copy2(patched_bcd, target_bcd)
            return "template-patched"
    shutil.copy2(template_bcd, target_bcd)
    logger.warn(
        "BCD-Template konnte nicht automatisch auf den Windows-UEFI-Loader gepatcht werden. "
        "Es wird das unveraenderte Template verwendet."
    )
    return "template"



def install_boot_files(
    windows_mount: Path,
    efi_mount: Path,
    logger: Logger,
    *,
    efi_partition: Path,
    windows_partition: Path,
    disk_device: Path,
) -> str:
    efi_source = windows_mount / "Windows" / "Boot" / "EFI"
    resources_source = windows_mount / "Windows" / "Boot" / "Resources"
    fonts_source = windows_mount / "Windows" / "Boot" / "Fonts"
    bcd_template = windows_mount / "Windows" / "System32" / "config" / "BCD-Template"
    dvd_bcd = windows_mount / "Windows" / "Boot" / "DVD" / "EFI" / "BCD"

    if not efi_source.exists():
        raise ToolError(f"EFI-Bootdateien fehlen in der Windows-Partition: {efi_source}")
    if not any(path.exists() for path in (bcd_template, dvd_bcd)):
        raise ToolError(f"BCD-Template fehlt in der Windows-Partition: {bcd_template}")

    microsoft_boot = efi_mount / "EFI" / "Microsoft" / "Boot"
    fallback_boot = efi_mount / "EFI" / "Boot"
    microsoft_boot.mkdir(parents=True, exist_ok=True)
    fallback_boot.mkdir(parents=True, exist_ok=True)

    copytree_merge(efi_source, microsoft_boot)
    copytree_merge(resources_source, microsoft_boot / "Resources")
    copytree_merge(fonts_source, microsoft_boot / "Fonts")

    copytree_merge(efi_source, fallback_boot)
    copytree_merge(resources_source, fallback_boot / "Resources")
    copytree_merge(fonts_source, fallback_boot / "Fonts")

    efi_partuuid = blkid_value(efi_partition, "PARTUUID", logger)
    windows_partuuid = blkid_value(windows_partition, "PARTUUID", logger)
    disk_guid = blkid_value(disk_device, "PTUUID", logger)

    try:
        bcd_origin = write_seeded_donor_bcd(
            microsoft_boot / "BCD",
            efi_partuuid=efi_partuuid,
            windows_partuuid=windows_partuuid,
            disk_guid=disk_guid,
            logger=logger,
        )
    except ToolError as exc:
        logger.warn(f"Windows-BCD-Donor fehlgeschlagen ({exc}). Fallback auf Template.")
        if bcd_template.exists():
            bcd_origin = build_patched_bcd_template(bcd_template, microsoft_boot / "BCD", logger)
        else:
            shutil.copy2(dvd_bcd, microsoft_boot / "BCD")
            bcd_origin = "dvd"
    shutil.copy2(microsoft_boot / "BCD", fallback_boot / "BCD")

    bootmgfw = microsoft_boot / "bootmgfw.efi"
    if not bootmgfw.exists():
        raise ToolError(f"bootmgfw.efi wurde nach dem Kopieren nicht gefunden: {bootmgfw}")
    shutil.copy2(bootmgfw, fallback_boot / "BOOTX64.EFI")

    logger.warn(
        f"BCD-Quelle '{bcd_origin}' wurde als Linux-Best-Effort auf die EFI-Partition kopiert. "
        "Falls die VM nicht bootet, einmalig in WinPE/Setup reparieren mit: "
        "bcdboot C:\\Windows /s S: /f UEFI"
    )
    return f"{bcd_origin}-copied"


def cleanup(state: ConversionState, logger: Logger) -> None:
    for mountpoint in reversed(state.mountpoints):
        if mountpoint.exists():
            run_command(["umount", str(mountpoint)], logger, check=False)
    if state.nbd_device is not None:
        disconnect_nbd(state.nbd_device, logger)
    for tempdir in reversed(state.tempdirs):
        safe_rmtree(tempdir)


def release_state(state: ConversionState, logger: Logger) -> None:
    run_command(["sync"], logger, check=False)
    cleanup(state, logger)
    state.nbd_device = None
    state.mountpoints.clear()
    state.tempdirs.clear()


def check_qcow2(path: Path, logger: Logger, *, retries: int = 10, delay: float = 1.0) -> None:
    last_error = ""
    for attempt in range(1, retries + 1):
        result = run_command(["qemu-img", "check", "-f", "qcow2", str(path)], logger, check=False)
        if result.returncode == 0:
            return
        stderr = result.stderr if isinstance(result.stderr, str) else result.stderr.decode("utf-8", "replace")
        last_error = stderr.strip()
        if 'Failed to get shared "write" lock' not in last_error or attempt == retries:
            break
        logger.debug(f"qemu-img check wartet auf Lock-Freigabe ({attempt}/{retries})")
        time.sleep(delay)
    raise ToolError(
        f"Befehl fehlgeschlagen: qemu-img check -f qcow2 {shlex.quote(str(path))}\n{last_error or 'Unbekannter Fehler'}"
    )


def sha256sum(path: Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as handle:
        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
            digest.update(chunk)
    return digest.hexdigest()


def parse_start_conf(path: Path) -> dict[str, list[dict[str, str]]]:
    if not path.is_file():
        raise ToolError(f"start.conf nicht gefunden: {path}")

    sections: dict[str, list[dict[str, str]]] = {}
    current: dict[str, str] | None = None
    for raw_line in path.read_text(encoding="utf-8").splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#") or line.startswith(";"):
            continue
        if line.startswith("[") and line.endswith("]"):
            section_name = line[1:-1].strip()
            current = {}
            sections.setdefault(section_name, []).append(current)
            continue
        if current is None or "=" not in line:
            continue
        key, value = line.split("=", 1)
        current[key.strip()] = value.strip()
    return sections


def derive_start_conf_hints(path: Path) -> StartConfHints:
    sections = parse_start_conf(path)
    linbo = sections.get("LINBO", [{}])[0]
    os_section = sections.get("OS", [{}])[0]
    root_partition = os_section.get("Root") or os_section.get("Boot")
    partition_size = None
    partition_label = None
    if root_partition:
        for part in sections.get("Partition", []):
            if part.get("Dev") == root_partition:
                partition_size = part.get("Size")
                partition_label = part.get("Label")
                break
    return StartConfHints(
        root_partition=root_partition,
        partition_size=partition_size,
        partition_label=partition_label,
        system_type=linbo.get("SystemType"),
        group_name=linbo.get("Group"),
    )


def apply_start_conf_defaults(args: argparse.Namespace, logger: Logger) -> None:
    if not args.start_conf:
        return
    hints = derive_start_conf_hints(Path(args.start_conf).resolve())
    if args.layout != "linuxmuster-partition":
        return
    if args.target_partition == DEFAULT_TARGET_PARTITION and hints.root_partition:
        args.target_partition = hints.root_partition
        logger.debug(f"Zielpartition aus start.conf uebernommen: {args.target_partition}")
    if args.disk_size == DEFAULT_DISK_SIZE and hints.partition_size:
        args.disk_size = hints.partition_size
        logger.debug(f"Partitionsgroesse aus start.conf uebernommen: {args.disk_size}")
    if args.ntfs_label == DEFAULT_NTFS_LABEL and hints.partition_label:
        args.ntfs_label = hints.partition_label
        logger.debug(f"NTFS-Label aus start.conf uebernommen: {args.ntfs_label}")


def detect_linuxmuster_reference_qcow2(reference_dir: Path, logger: Logger) -> Path | None:
    if not reference_dir.exists():
        raise ToolError(f"Referenzpfad nicht gefunden: {reference_dir}")
    if reference_dir.is_file():
        if reference_dir.suffix.lower() != ".qcow2":
            raise ToolError(f"Referenzpfad ist keine qcow2-Datei: {reference_dir}")
        return reference_dir

    matches = sorted(path for path in reference_dir.glob("*.qcow2") if path.is_file())
    if not matches:
        logger.debug(f"Keine Referenz-qcow2 im Verzeichnis gefunden: {reference_dir}")
        return None
    if len(matches) > 1:
        names = ", ".join(path.name for path in matches)
        logger.warn(
            "Mehrere Referenz-qcow2-Dateien gefunden; verwende den ersten Treffer: "
            f"{matches[0].name} ({names})"
        )
    return matches[0]


def write_linuxmuster_marker(windows_mount: Path, image_base: str, logger: Logger) -> None:
    marker = windows_mount / ".linbo"
    marker.write_text(image_base + "\n", encoding="utf-8")
    logger.debug(f"Linuxmuster-Marker geschrieben: {marker}")


def extract_partition_number(device: str | None) -> str | None:
    if not device:
        return None
    base = os.path.basename(device.rstrip("/"))
    digits: list[str] = []
    for char in reversed(base):
        if char.isdigit():
            digits.append(char)
            continue
        if digits:
            break
    if not digits:
        return None
    return "".join(reversed(digits))


def linuxmuster_partname_candidates(target_partition: str | None, boot_dir: Path) -> list[str]:
    candidates: list[str] = []
    seen: set[str] = set()

    def add(value: str | None) -> None:
        if not value or value in seen:
            return
        seen.add(value)
        candidates.append(value)

    if target_partition:
        add(os.path.basename(target_partition.rstrip("/")))

    for source in sorted(boot_dir.glob("BCD.*.*")):
        parts = source.name.split(".", 2)
        if len(parts) == 3:
            add(parts[2])

    partition_number = extract_partition_number(target_partition)
    if partition_number:
        for template in (
            "disk0p{n}",
            "sda{n}",
            "hda{n}",
            "vda{n}",
            "xvda{n}",
            "nvme0n1p{n}",
            "mmcblk0p{n}",
        ):
            add(template.format(n=partition_number))
    return candidates


def write_linuxmuster_ntfs_id(boot_dir: Path, ntfs_device: Path | None, logger: Logger) -> None:
    if ntfs_device is None:
        return
    ntfs_id_path = boot_dir / "ntfs.id"
    with ntfs_device.open("rb") as handle:
        handle.seek(8 * 9)
        data = handle.read(8)
    if len(data) != 8:
        raise ToolError(f"ntfs.id konnte nicht aus {ntfs_device} gelesen werden.")
    ntfs_id_path.write_bytes(data)
    logger.debug(f"Linuxmuster-ntfs.id aktualisiert: {ntfs_id_path}")


def materialize_linuxmuster_backups(
    windows_mount: Path,
    group_name: str | None,
    target_partition: str | None,
    ntfs_device: Path | None,
    logger: Logger,
) -> None:
    boot_dir = windows_mount / "EFI" / "Microsoft" / "Boot"
    if not boot_dir.is_dir():
        return

    write_linuxmuster_ntfs_id(boot_dir, ntfs_device, logger)

    if not group_name:
        return

    partnames = linuxmuster_partname_candidates(target_partition, boot_dir)
    bcd_path = boot_dir / "BCD"
    if bcd_path.is_file():
        removed = 0
        for source in sorted(boot_dir.glob("BCD.*.*")):
            source.unlink()
            removed += 1
        created = 0
        for partname in partnames:
            destination = boot_dir / f"BCD.{group_name}.{partname}"
            shutil.copy2(bcd_path, destination)
            created += 1
            logger.debug(f"Linuxmuster-BCD-Backup geschrieben: {destination.name}")
        logger.debug(f"Linuxmuster-BCD-Backups neu erzeugt: entfernt={removed}, erstellt={created}")

    bsmbr_bytes = None
    for source in sorted(boot_dir.glob("bsmbr.*")):
        if bsmbr_bytes is None:
            bsmbr_bytes = source.read_bytes()
        source.unlink()
    if bsmbr_bytes is not None:
        destination = boot_dir / f"bsmbr.{group_name}"
        destination.write_bytes(bsmbr_bytes)
        logger.debug(f"Linuxmuster-MBR-Backup geschrieben: {destination.name}")


def apply_linuxmuster_reference_boot_seed(
    windows_mount: Path,
    image_base: str,
    reference_dir: Path | None,
    group_name: str | None,
    target_partition: str | None,
    ntfs_device: Path | None,
    logger: Logger,
) -> bool:
    write_linuxmuster_marker(windows_mount, image_base, logger)
    if reference_dir is None:
        logger.warn(
            "Kein Referenzverzeichnis fuer Linuxmuster-Bootmetadaten angegeben. "
            "Das Partitionsimage wird ohne .guid.* und ohne donor-EFI-Seed erstellt."
        )
        return False

    donor_image = detect_linuxmuster_reference_qcow2(reference_dir, logger)
    if donor_image is None:
        logger.warn(
            f"Im Referenzverzeichnis wurde keine qcow2-Datei gefunden: {reference_dir}. "
            "Es werden nur interne Sidecars erzeugt."
        )
        return False

    logger.step(f"Uebernehme Linuxmuster-Bootmetadaten aus Referenzimage: {donor_image.name}")
    donor_nbd = connect_nbd(donor_image, logger, read_only=True)
    donor_mount = Path(tempfile.mkdtemp(prefix="wim2qcow2-donor-", dir="/tmp"))
    copied_guids = 0
    copied_boot_dir = False
    try:
        mount_partition(donor_nbd, donor_mount, logger, fs_type="ntfs3", options="ro")

        for relative_name in (".guid.disk", ".guid.efi", ".guid.part"):
            source = donor_mount / relative_name
            if not source.is_file():
                continue
            shutil.copy2(source, windows_mount / relative_name)
            copied_guids += 1
            logger.debug(f"Uebernommen aus Referenzimage: {relative_name}")

        donor_boot_dir = donor_mount / "EFI" / "Microsoft" / "Boot"
        target_boot_dir = windows_mount / "EFI" / "Microsoft" / "Boot"
        if donor_boot_dir.is_dir():
            if target_boot_dir.exists():
                shutil.rmtree(target_boot_dir)
            target_boot_dir.parent.mkdir(parents=True, exist_ok=True)
            shutil.copytree(donor_boot_dir, target_boot_dir)
            copied_boot_dir = True
            logger.debug(f"Uebernommen aus Referenzimage: {donor_boot_dir}")
    finally:
        run_command(["umount", str(donor_mount)], logger, check=False)
        disconnect_nbd(donor_nbd, logger)
        safe_rmtree(donor_mount)

    if copied_guids != 3 or not copied_boot_dir:
        logger.warn(
            "Referenzimage enthaelt keinen vollstaendigen Linuxmuster-Bootsatz "
            "(.guid.disk/.guid.efi/.guid.part plus EFI/Microsoft/Boot). "
            "Falle auf interne Hook-Logik zurueck."
        )
        return False
    materialize_linuxmuster_backups(windows_mount, group_name, target_partition, ntfs_device, logger)
    return True


