def linuxmuster_bcd_seed_snippet() -> str:
    snippet = textwrap.dedent(
        """\\
        find_by_label() {
          label="$1"
          dev=""
          if command -v blkid >/dev/null 2>&1; then
            dev=$(blkid -L "$label" 2>/dev/null || true)
          fi
          if [ -z "$dev" ] && [ -e "/dev/disk/by-label/$label" ]; then
            dev=$(readlink -f "/dev/disk/by-label/$label" 2>/dev/null || true)
          fi
          printf '%s' "$dev"
        }

        parent_disk() {
          dev="$1"
          [ -n "$dev" ] || return 1
          name=$(basename "$dev")
          sys="/sys/class/block/$name"
          [ -e "$sys" ] || return 1
          real=$(readlink -f "$sys") || return 1
          parent=$(basename "$(dirname "$real")")
          [ "$parent" != "$name" ] || return 1
          printf '/dev/%s' "$parent"
        }

        current_bcd_default_guid() {
          bcd_path="$1"
          tmp_reg=/tmp/wim2qcow2_bcd_default.reg
          rm -f "$tmp_reg"
          command -v reged >/dev/null 2>&1 || return 1
          reged -x "$bcd_path" 'HKEY_LOCAL_MACHINE\\BCD00000000' 'Objects\\__BCD_BOOTMGR_GUID__\\Elements\\23000003' "$tmp_reg" >/tmp/wim2qcow2_bcd_default.log 2>&1 || true
          [ -s "$tmp_reg" ] || return 1
          awk -F'"' '/"Element"=/{print $4; exit}' "$tmp_reg"
        }

        guid_to_le_csv() {
          guid=$(printf '%s' "$1" | tr 'A-F' 'a-f' | tr -d '{}-')
          [ "${#guid}" -eq 32 ] || return 1
          p1=${guid:0:8}
          p2=${guid:8:4}
          p3=${guid:12:4}
          p4=${guid:16:4}
          p5=${guid:20:12}
          printf '%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s' \
            "${p1:6:2}" "${p1:4:2}" "${p1:2:2}" "${p1:0:2}" \
            "${p2:2:2}" "${p2:0:2}" \
            "${p3:2:2}" "${p3:0:2}" \
            "${p4:0:2}" "${p4:2:2}" \
            "${p5:0:2}" "${p5:2:2}" "${p5:4:2}" "${p5:6:2}" "${p5:8:2}" "${p5:10:2}"
        }

        device_element_hex() {
          part_guid="$1"
          disk_guid="$2"
          part_le=$(guid_to_le_csv "$part_guid") || return 1
          disk_le=$(guid_to_le_csv "$disk_guid") || return 1
          printf '00,00,00,00,00,00,00,00,00,00,00,00,00,00,00,00,06,00,00,00,00,00,00,00,48,00,00,00,00,00,00,00,%s,00,00,00,00,00,00,00,00,%s,00,00,00,00,00,00,00,00,00,00,00,00,00,00,00,00' "$part_le" "$disk_le"
        }

        donor_bcd_to_file() {
          target="$1"
          cat <<'EOF' | base64 -d > "$target"
__BCD_DONOR_B64__
EOF
        }

        donor_bcd_patch_reg() {
          efi_partuuid="$1"
          win_partuuid="$2"
          disk_guid="$3"
          bootmgr_hex=$(device_element_hex "$efi_partuuid" "$disk_guid") || return 1
          win_hex=$(device_element_hex "$win_partuuid" "$disk_guid") || return 1
          cat <<EOF
Windows Registry Editor Version 5.00

[HKEY_LOCAL_MACHINE\\BCD00000000\\Objects\\__BCD_BOOTMGR_GUID__\\Elements\\11000001]
"Element"=hex:$bootmgr_hex

[HKEY_LOCAL_MACHINE\\BCD00000000\\Objects\\__BCD_DONOR_RESUME_GUID__\\Elements\\11000001]
"Element"=hex:$win_hex

[HKEY_LOCAL_MACHINE\\BCD00000000\\Objects\\__BCD_DONOR_LOADER_GUID__\\Elements\\11000001]
"Element"=hex:$win_hex

[HKEY_LOCAL_MACHINE\\BCD00000000\\Objects\\__BCD_DONOR_LOADER_GUID__\\Elements\\21000001]
"Element"=hex:$win_hex
EOF
        }

        write_seeded_donor_bcd() {
          efi_dev="$1"
          root_dev="$2"
          target_bcd="$3"
          [ -n "$efi_dev" ] || return 1
          [ -n "$root_dev" ] || return 1
          disk_dev=$(parent_disk "$root_dev") || return 1
          efi_partuuid=$(blkid -s PARTUUID -o value "$efi_dev" 2>/dev/null || true)
          win_partuuid=$(blkid -s PARTUUID -o value "$root_dev" 2>/dev/null || true)
          disk_guid=$(blkid -s PTUUID -o value "$disk_dev" 2>/dev/null || true)
          [ -n "$efi_partuuid" ] && [ -n "$win_partuuid" ] && [ -n "$disk_guid" ] || return 1
          tmp_bcd=/tmp/wim2qcow2_bcd_donor
          tmp_reg=/tmp/wim2qcow2_bcd_seed.reg
          donor_bcd_to_file "$tmp_bcd" || return 1
          donor_bcd_patch_reg "$efi_partuuid" "$win_partuuid" "$disk_guid" > "$tmp_reg" || return 1
          command -v reged >/dev/null 2>&1 || return 1
          reged -I -C "$tmp_bcd" 'HKEY_LOCAL_MACHINE\\BCD00000000' "$tmp_reg" >/tmp/wim2qcow2_bcd_seed.log 2>&1
          rc=$?
          [ "$rc" -eq 0 ] || [ "$rc" -eq 2 ] || return 1
          guid=$(current_bcd_default_guid "$tmp_bcd" 2>/dev/null || true)
          [ "$guid" = "__BCD_DONOR_LOADER_GUID__" ] || return 1
          cp -f "$tmp_bcd" "$target_bcd"
        }

        write_patched_template_bcd() {
          template_bcd="$1"
          target_bcd="$2"
          tmp_bcd=/tmp/wim2qcow2_bcd_template
          tmp_reg=/tmp/wim2qcow2_bcd_fix.reg
          cat > "$tmp_reg" <<'EOF'
Windows Registry Editor Version 5.00

[HKEY_LOCAL_MACHINE\\BCD00000000\\Objects\\__BCD_BOOTMGR_GUID__\\Elements\\23000003]
"Element"="__BCD_TEMPLATE_EFI_GUID__"
EOF
          cp -f "$template_bcd" "$tmp_bcd" || return 1
          if command -v reged >/dev/null 2>&1; then
            reged -I -C "$tmp_bcd" 'HKEY_LOCAL_MACHINE\\BCD00000000' "$tmp_reg" >/tmp/wim2qcow2_bcd_fix.log 2>&1 || true
            guid=$(current_bcd_default_guid "$tmp_bcd" 2>/dev/null || true)
            if [ "$guid" != "__BCD_TEMPLATE_EFI_GUID__" ]; then
              cp -f "$template_bcd" "$tmp_bcd" || return 1
            fi
          fi
          cp -f "$tmp_bcd" "$target_bcd"
        }

        repair_efi_boot() {
          root_mnt="$1"
          efi_mnt="$2"
          root_dev="$3"
          efi_dev="$4"
          efi_source="$root_mnt/Windows/Boot/EFI"
          fonts_source="$root_mnt/Windows/Boot/Fonts"
          resources_source="$root_mnt/Windows/Boot/Resources"
          template_bcd="$root_mnt/Windows/System32/config/BCD-Template"
          ms_boot="$efi_mnt/EFI/Microsoft/Boot"
          fb_boot="$efi_mnt/EFI/Boot"

          mkdir -p "$ms_boot" "$fb_boot"

          if [ -f "$ms_boot/BCD" ] && [ -f "$ms_boot/bootmgfw.efi" ]; then
            current_guid=$(current_bcd_default_guid "$ms_boot/BCD" 2>/dev/null || true)
            case "$current_guid" in
              "__BCD_DVD_SETUP_GUID__"|"__BCD_TEMPLATE_SETUP_GUID__"|"__BCD_TEMPLATE_EFI_GUID__")
                echo '# replacing setup-style Microsoft EFI store'
                ;;
              *)
                echo '# keeping existing Microsoft EFI store'
                cp -f "$ms_boot/bootmgfw.efi" "$fb_boot/BOOTX64.EFI" 2>/dev/null || true
                cp -f "$ms_boot/BCD" "$fb_boot/BCD" 2>/dev/null || true
                [ -f "$ms_boot/BCD.LOG" ] && cp -f "$ms_boot/BCD.LOG" "$fb_boot/BCD.LOG" 2>/dev/null || true
                [ -f "$ms_boot/BOOTSTAT.DAT" ] && cp -f "$ms_boot/BOOTSTAT.DAT" "$fb_boot/BOOTSTAT.DAT" 2>/dev/null || true
                return 0
                ;;
            esac
          fi

          [ -d "$efi_source" ] || return 0

          echo '# populating missing EFI boot files from Windows partition'
          cp -a "$efi_source/." "$ms_boot/" 2>/dev/null || true
          cp -a "$efi_source/." "$fb_boot/" 2>/dev/null || true

          if [ -d "$fonts_source" ]; then
            mkdir -p "$ms_boot/Fonts" "$fb_boot/Fonts"
            cp -a "$fonts_source/." "$ms_boot/Fonts/" 2>/dev/null || true
            cp -a "$fonts_source/." "$fb_boot/Fonts/" 2>/dev/null || true
          fi

          if [ -d "$resources_source" ]; then
            mkdir -p "$ms_boot/Resources" "$fb_boot/Resources"
            cp -a "$resources_source/." "$ms_boot/Resources/" 2>/dev/null || true
            cp -a "$resources_source/." "$fb_boot/Resources/" 2>/dev/null || true
          fi

          rm -f "$ms_boot/BCD.LOG"* "$fb_boot/BCD.LOG"* 2>/dev/null || true
          if write_seeded_donor_bcd "$efi_dev" "$root_dev" "$ms_boot/BCD"; then
            echo '# using seeded Windows BCD donor'
          elif [ -f "$template_bcd" ]; then
            echo '# donor BCD seed failed, using patched BCD template'
            write_patched_template_bcd "$template_bcd" "$ms_boot/BCD" || cp -f "$template_bcd" "$ms_boot/BCD"
          fi
          if [ -f "$ms_boot/BCD" ]; then
            cp -f "$ms_boot/BCD" "$fb_boot/BCD"
          fi
          if [ -f "$ms_boot/bootmgfw.efi" ]; then
            cp -f "$ms_boot/bootmgfw.efi" "$fb_boot/BOOTX64.EFI"
          fi
        }
        """
    )
    return (
        snippet
        .replace("__BCD_DONOR_B64__", BCD_DONOR_B64)
        .replace("__BCD_BOOTMGR_GUID__", BCD_BOOTMGR_GUID)
        .replace("__BCD_TEMPLATE_EFI_GUID__", BCD_TEMPLATE_EFI_GUID)
        .replace("__BCD_TEMPLATE_SETUP_GUID__", BCD_TEMPLATE_SETUP_GUID)
        .replace("__BCD_DVD_SETUP_GUID__", BCD_DVD_SETUP_GUID)
        .replace("__BCD_DONOR_LOADER_GUID__", BCD_DONOR_LOADER_GUID)
        .replace("__BCD_DONOR_RESUME_GUID__", BCD_DONOR_RESUME_GUID)
    )


def legacy_linuxmuster_prestart_template() -> str:
    return (
        textwrap.dedent(
            """\\
            # linuxmuster wim2qcow2 generated prestart
            # Bewahrt einen bestehenden Windows-EFI-Store, fuellt fehlende Dateien best-effort nach
            # und setzt fuer den naechsten Boot den nativen UEFI-Eintrag von Windows.

            [ -r /conf/linbo ] && . /conf/linbo
            [ -r /conf/os.1 ] && . /conf/os.1

            """
        )
        + linuxmuster_bcd_seed_snippet()
        + textwrap.dedent(
            """\\

            set_windows_bootnext() {
              command -v efibootmgr >/dev/null 2>&1 || return 0
              bootnum=$(efibootmgr | awk '/Windows Boot Manager/ {gsub(/^Boot/,"",$1); gsub(/\\*.*/,"",$1); print $1; exit}')
              if [ -n "$bootnum" ]; then
                if efibootmgr -n "$bootnum" >/dev/null 2>&1; then
                  echo "# set BootNext to Windows Boot Manager ($bootnum)"
                fi
              fi
            }

            ROOT_MNT=/mnt
            CACHE_MNT=/cache
            EFI_MNT=/tmp/wim2qcow2_efi
            ROOT_DEV="${root:-}"
            CACHE_DEV="${cache:-}"
            EFI_DEV=$(find_by_label efi)
            ROOT_OWN=0
            CACHE_OWN=0
            EFI_OWN=0

            mkdir -p "$ROOT_MNT" "$CACHE_MNT" "$EFI_MNT"

            if [ -z "$ROOT_DEV" ]; then
              ROOT_DEV=$(find_by_label windows)
            fi

            if [ -n "$ROOT_DEV" ] && ! grep -qs " $ROOT_MNT " /proc/mounts; then
              if command -v linbo_mount >/dev/null 2>&1; then
                linbo_mount "$ROOT_DEV" "$ROOT_MNT" >/dev/null 2>&1 || mount "$ROOT_DEV" "$ROOT_MNT" >/dev/null 2>&1 || true
              else
                mount "$ROOT_DEV" "$ROOT_MNT" >/dev/null 2>&1 || true
              fi
              grep -qs " $ROOT_MNT " /proc/mounts && ROOT_OWN=1
            fi

            if [ -n "$EFI_DEV" ] && ! grep -qs " $EFI_MNT " /proc/mounts; then
              if command -v linbo_mount >/dev/null 2>&1; then
                linbo_mount "$EFI_DEV" "$EFI_MNT" >/dev/null 2>&1 || mount "$EFI_DEV" "$EFI_MNT" >/dev/null 2>&1 || true
              else
                mount "$EFI_DEV" "$EFI_MNT" >/dev/null 2>&1 || true
              fi
              grep -qs " $EFI_MNT " /proc/mounts && EFI_OWN=1
            fi

            if grep -qs " $ROOT_MNT " /proc/mounts && grep -qs " $EFI_MNT " /proc/mounts; then
              repair_efi_boot "$ROOT_MNT" "$EFI_MNT" "$ROOT_DEV" "$EFI_DEV"
              sync
            fi

            set_windows_bootnext

            if [ -n "${HOSTNAME:-}" ] && [ "${HOSTNAME#*vdi}" != "$HOSTNAME" ]; then
              if [ -z "$CACHE_DEV" ]; then
                CACHE_DEV=$(find_by_label cache)
              fi
              if [ -n "$CACHE_DEV" ] && ! grep -qs " $CACHE_MNT " /proc/mounts; then
                if command -v linbo_mount >/dev/null 2>&1; then
                  linbo_mount "$CACHE_DEV" "$CACHE_MNT" >/dev/null 2>&1 || mount "$CACHE_DEV" "$CACHE_MNT" >/dev/null 2>&1 || true
                else
                  mount "$CACHE_DEV" "$CACHE_MNT" >/dev/null 2>&1 || true
                fi
                grep -qs " $CACHE_MNT " /proc/mounts && CACHE_OWN=1
              fi
              if grep -qs " $CACHE_MNT " /proc/mounts && ls "$CACHE_MNT"/*.reg >/dev/null 2>&1; then
                patch=/tmp/patch.reg
                sed "s|{\\$HostName\\$}|$HOSTNAME|g" "$CACHE_MNT"/*.reg > "$patch"
                linbo_patch_registry "$patch"
                rm -f "$patch"
              fi
            fi

            [ "$EFI_OWN" -eq 1 ] && umount "$EFI_MNT" >/dev/null 2>&1 || true
            [ "$ROOT_OWN" -eq 1 ] && umount "$ROOT_MNT" >/dev/null 2>&1 || true
            [ "$CACHE_OWN" -eq 1 ] && umount "$CACHE_MNT" >/dev/null 2>&1 || true
            rmdir "$EFI_MNT" >/dev/null 2>&1 || true
            """
        )
    )


