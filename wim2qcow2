def parse_env_value_as_bool(value: str) -> bool:
    return value.strip().lower() in {"1", "true", "yes", "y", "on", "ja"}


def parse_env_file(path: Path) -> dict[str, str]:
    if not path.is_file():
        raise ToolError(f"env-Datei nicht gefunden: {path}")
    values: dict[str, str] = {}
    for raw_line in path.read_text(encoding="utf-8").splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#"):
            continue
        if line.startswith("export "):
            line = line[7:].strip()
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        values[key.strip().upper()] = value.strip().strip('"').strip("'")
    return values


def apply_env_defaults(args: argparse.Namespace, parser: argparse.ArgumentParser, env_values: dict[str, str]) -> argparse.Namespace:
    key_map = {
        "INPUT": "input",
        "OUTPUT": "output",
        "INDEX": "index",
        "DISK_SIZE": "disk_size",
        "LAYOUT": "layout",
        "START_CONF": "start_conf",
        "TARGET_PARTITION": "target_partition",
        "COPY_SIDECARS_FROM": "copy_sidecars_from",
        "NTFS_LABEL": "ntfs_label",
        "SANITIZE_LOGODIDAKT": "sanitize_logodidakt",
        "INSPECT": "inspect",
        "FORCE": "force",
        "LOGFILE": "logfile",
        "VERBOSE": "verbose",
    }

    for env_key, attr in key_map.items():
        if env_key not in env_values:
            continue
        current = getattr(args, attr)
        default = parser.get_default(attr)
        if current not in (None, default, False):
            continue
        raw = env_values[env_key]
        if attr == "index":
            setattr(args, attr, int(raw))
        elif attr in {"inspect", "force", "verbose", "sanitize_logodidakt"}:
            setattr(args, attr, parse_env_value_as_bool(raw))
        else:
            setattr(args, attr, raw)
    return args


def run_interactive_wizard(args: argparse.Namespace) -> argparse.Namespace:
    print("Interaktiver Modus")
    print("")

    detected_wims = sorted(Path.cwd().glob("*.wim"))
    selected_wim = choose_detected_path(detected_wims, "Gefundene WIM-Dateien im aktuellen Verzeichnis:", kind="file") if detected_wims else None
    args.input = prompt_existing_path("Pfad zur WIM-Datei", default=selected_wim, kind="file")

    require_tools(("wimlib-imagex",))
    temp_logger = Logger(verbose=False, logfile=None)
    metadata = parse_wim_metadata(Path(args.input).resolve(), temp_logger)
    print("")
    print_wim_summary(metadata)
    print("")

    args.inspect = prompt_yes_no("Nur analysieren und noch nichts konvertieren", default=False)
    if args.inspect:
        return args

    if len(metadata.images) == 1:
        args.index = metadata.images[0].index
    else:
        default_index = str(metadata.images[0].index)
        while True:
            selected = prompt_text("WIM-Index", default=default_index)
            try:
                args.index = int(selected)
                choose_image(metadata, args.index)
                break
            except (ValueError, ToolError):
                print("Ungueltiger WIM-Index.")

    args.layout = prompt_choice(
        "Ausgabeformat",
        (
            ("Linuxmuster-Partitionsimage", "linuxmuster-partition"),
            ("Bootfaehiges Voll-Disk-qcow2", "full-disk-gpt"),
        ),
        args.layout,
    )

    default_output = args.output or str(default_output_for_input(Path(args.input).resolve()))
    args.output = prompt_output_path("Pfad zur Ausgabe-qcow2 (inkl. Dateiname)", default_output)

    detected_start_conf = sorted(Path("/srv/linbo").glob("start.conf*")) if args.layout == "linuxmuster-partition" else []
    default_start_conf = guess_start_conf_from_output(args.output) or args.start_conf
    if not default_start_conf and detected_start_conf:
        default_start_conf = str(detected_start_conf[0].resolve())
    if detected_start_conf:
        default_start_conf = choose_detected_path(
            detected_start_conf,
            "Gefundene start.conf-Dateien:",
            kind="file",
            default_path=default_start_conf,
            limit=10,
        )
    args.start_conf = prompt_existing_path(
        "LINBO start.conf (Enter = Auswahl oben, '-' = keine Ableitung)",
        default=default_start_conf,
        kind="file",
        allow_empty=True,
    ) if args.layout == "linuxmuster-partition" else None

    apply_start_conf_defaults(args, temp_logger)

    args.disk_size = prompt_text("Groesse der Zielpartition / des Images", default=args.disk_size)
    args.ntfs_label = prompt_text("NTFS-Label", default=args.ntfs_label)

    if args.layout == "linuxmuster-partition":
        args.target_partition = prompt_text("Zielpartition fuer .info", default=args.target_partition)
        reference_dir = prompt_existing_path(
            "Referenzverzeichnis fuer .reg/.desc und Linuxmuster-Boot-Seed (.qcow2)",
            default=args.copy_sidecars_from,
            kind="dir",
            allow_empty=True,
        )
        args.copy_sidecars_from = reference_dir or None
    else:
        args.target_partition = DEFAULT_TARGET_PARTITION
        args.copy_sidecars_from = None

    args.sanitize_logodidakt = prompt_yes_no(
        "LogoDidakt-/Domain-/Autologon-Reste entfernen",
        default=args.sanitize_logodidakt,
    )

    args.logfile = prompt_text("Logfile (leer = keines)", default=args.logfile, allow_empty=True) or None
    args.verbose = prompt_yes_no("Verbose-Ausgabe aktivieren", default=args.verbose)
    args.force = prompt_yes_no("Vorhandene .partial-Datei ueberschreiben falls noetig", default=args.force)

    summarize_args(args)
    if not prompt_yes_no("Konvertierung jetzt starten", default=True):
        raise ToolError("Abgebrochen.")

    return args


def ensure_output_target(output_path: Path, force: bool) -> Path:
    partial = output_path.with_name(output_path.name + ".partial")
    if output_path.exists() and not force:
        raise ToolError(f"Zieldatei existiert bereits: {output_path}")
    if partial.exists():
        if force:
            partial.unlink()
        else:
            raise ToolError(f"Partielle Zieldatei existiert bereits: {partial}")
    output_path.parent.mkdir(parents=True, exist_ok=True)
    return partial


def check_free_space(output_dir: Path, image: WimImage, logger: Logger) -> None:
    usage = shutil.disk_usage(output_dir)
    logger.debug(f"Freier Platz in {output_dir}: {human_bytes(usage.free)}")
    if usage.free < 10 * GIB:
        logger.warn(
            f"Weniger als 10 GiB frei im Ziel-Dateisystem ({human_bytes(usage.free)}). "
            "Die Konvertierung wird sehr wahrscheinlich scheitern."
        )
    if usage.free < 2 * GIB:
        raise ToolError(
            f"Zu wenig freier Platz im Ziel-Dateisystem: {human_bytes(usage.free)}. "
            "Mindestens einige GiB Freiraum sind noetig."
        )
    recommended = image.total_bytes + 4 * GIB
    if usage.free < recommended:
        logger.warn(
            "Freier Platz ist kleiner als die logische Windows-Image-Groesse plus Puffer "
            f"({human_bytes(usage.free)} < {human_bytes(recommended)})."
        )


def validate_disk_size(image: WimImage, disk_size_bytes: int) -> None:
    minimum = image.total_bytes + 2 * GIB
    if disk_size_bytes < minimum:
        raise ToolError(
            f"--disk-size ist zu klein fuer das Image. "
            f"Mindestens {human_bytes(minimum)} sind sinnvoll, angefordert: {human_bytes(disk_size_bytes)}."
        )


def safe_rmtree(path: Path) -> None:
    if path.is_dir() and path.as_posix().startswith("/tmp/wim2qcow2-"):
        shutil.rmtree(path, ignore_errors=True)


def remove_path(path: Path, logger: Logger) -> None:
    if not path.exists():
        return
    if path.is_dir():
        shutil.rmtree(path)
    else:
        path.unlink()
    logger.debug(f"Entfernt: {path}")


def import_reg_patch(hive_path: Path, prefix: str, reg_text: str, logger: Logger) -> None:
    with tempfile.TemporaryDirectory(prefix="wim2qcow2-regpatch-", dir="/tmp") as tempdir_name:
        reg_path = Path(tempdir_name) / "patch.reg"
        reg_path.write_text(reg_text, encoding="utf-8")
        result = run_command(["reged", "-I", "-C", str(hive_path), prefix, str(reg_path)], logger, check=False)
        stdout = result.stdout if isinstance(result.stdout, str) else result.stdout.decode("utf-8", "replace")
        if result.returncode not in (0, 2) and "operation SUCCEEDED!" not in stdout:
            detail = result.stderr if isinstance(result.stderr, str) else result.stderr.decode("utf-8", "replace")
            raise ToolError(
                f"Registry-Import fehlgeschlagen: reged -I -C {shlex.quote(str(hive_path))} {shlex.quote(prefix)} {shlex.quote(str(reg_path))}\n"
                f"{detail.strip() or stdout.strip() or f'Exit-Code {result.returncode}'}"
            )


